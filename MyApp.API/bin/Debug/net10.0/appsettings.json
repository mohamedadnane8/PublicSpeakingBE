{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=MyAppDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-at-least-32-characters-long-for-jwt-signing",
    "Issuer": "MyApp",
    "Audience": "MyAppUsers",
    "ExpiryHours": "24"
  }
}
